# ===========================================
# 持久化记忆系统配置
# ===========================================

# 是否启用持久化记忆（true/false）
USE_PERSISTENT_MEMORY=true

# MySQL 数据库配置
DATABASE_URL=mysql+pymysql://root:postgres@localhost:3306/multiagent_ppt
SQL_ECHO=false  # 是否打印SQL语句（调试用）

# Redis 缓存配置
REDIS_URL=redis://redis:6379/0

# OpenAI API配置（用于向量embeddings）
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# LLM模型配置（保留原有配置）
# ===========================================
# LLM提供商：google, openai, deepseek, claude, ali
MODEL_PROVIDER=google
LLM_MODEL=gemini-2.0-flash-exp

# Google AI配置
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# OpenAI配置
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek配置
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Claude配置
# CLAUDE_API_KEY=your_claude_api_key_here

# Alibaba配置
# ALI_API_KEY=your_ali_api_key_here
