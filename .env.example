# MultiAgentPPT Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Authentication & Security Configuration
# ===========================================

# JWT Token Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multiagent_ppt
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_DB=multiagent_ppt
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=postgres

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0
DB_REDIS_HOST=localhost
DB_REDIS_PORT=6379
DB_REDIS_DB=0
DB_REDIS_PASSWORD=

# ===========================================
# MCP Tools Configuration
# ===========================================

# Bing Search API (Required for web_search)
# Get your key from: https://www.microsoft.com/cognitive-services/en-us/sign-up
BING_SEARCH_API_KEY=your_bing_search_api_key_here

# Unsplash API (Required for search_images)
# Get your key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API (Optional, alternative to Unsplash)
# Get your key from: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Redis Configuration (Optional, for state_store)
# If not provided, state_store will use file-based storage
REDIS_URL=redis://localhost:6379/0

# PPT Download Service (Required for xml_converter with generate_ppt=True)
# URL of the PPT generation service
DOWNLOAD_URL=http://localhost:3001

# ===========================================
# MCP Tools Advanced Configuration
# ===========================================

# Cache directory for fetch_url
MCP_CACHE_DIR=./data/mcp_cache

# Enable/disable caching for MCP tools
MCP_CACHE_ENABLED=true

# Cache TTL in seconds (default: 3600 = 1 hour)
MCP_CACHE_TTL=3600

# State storage directory (used when Redis is not configured)
MCP_STATE_DIR=./data/state

# Default namespace for state_store
MCP_STATE_NAMESPACE=default

# ===========================================
# LLM Configuration
# ===========================================

# Google API Key for Gemini
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# Vector Memory Configuration
# ===========================================

# Vector database URL (if using external vector DB)
# VECTOR_DB_URL=your_vector_db_url_here

# ===========================================
# Frontend Configuration
# ===========================================

# API endpoint for frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
