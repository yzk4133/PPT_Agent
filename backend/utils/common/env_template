# ==================== 环境配置 ====================
ENVIRONMENT=development  # development/staging/production
DEBUG=False
LOG_LEVEL=INFO

# ==================== API 密钥 ====================
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
CLAUDE_API_KEY=your_claude_key_here
GOOGLE_API_KEY=your_google_key_here
QWEN_API_KEY=your_qwen_key_here

# ==================== 数据库配置 ====================
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_DB=multiagent_ppt
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=password

DB_REDIS_HOST=localhost
DB_REDIS_PORT=6379
DB_REDIS_DB=0
# DB_REDIS_PASSWORD=  # 可选

DB_POOL_SIZE=50
DB_MAX_OVERFLOW=20

# ==================== Feature Flags ====================
# 架构相关
FEATURE_USE_FLAT_ARCHITECTURE=True  # 使用扁平化架构
FEATURE_USE_PERSISTENT_MEMORY=True  # 使用持久化记忆

# 功能相关
FEATURE_ENABLE_VECTOR_CACHE=True  # 向量缓存
FEATURE_ENABLE_USER_PREFERENCES=True  # 用户偏好学习
FEATURE_ENABLE_QUALITY_CHECK=True  # PPT 质量检查

# 工具相关
FEATURE_ENABLE_TOOL_HOT_RELOAD=False  # 工具热加载（实验性）
FEATURE_ENABLE_MCP_TOOLS=True  # MCP 工具

# 降级相关
FEATURE_ENABLE_AUTO_FALLBACK=True  # 自动降级

# ==================== Agent 配置 ====================
# Split Topic Agent
AGENT_SPLIT_TOPIC_PROVIDER=deepseek
AGENT_SPLIT_TOPIC_MODEL=deepseek-chat
AGENT_SPLIT_TOPIC_FALLBACK_MODEL=deepseek-chat
AGENT_SPLIT_TOPIC_TEMPERATURE=0.3
AGENT_SPLIT_TOPIC_MAX_TOKENS=2048
AGENT_SPLIT_TOPIC_TIMEOUT=60
AGENT_SPLIT_TOPIC_MAX_RETRIES=3

# Research Agent
AGENT_RESEARCH_PROVIDER=deepseek
AGENT_RESEARCH_MODEL=deepseek-chat
AGENT_RESEARCH_FALLBACK_MODEL=deepseek-chat
AGENT_RESEARCH_TEMPERATURE=0.7
AGENT_RESEARCH_MAX_TOKENS=8192
AGENT_RESEARCH_MAX_CONCURRENCY=3
AGENT_RESEARCH_TIMEOUT=120
AGENT_RESEARCH_MAX_RETRIES=3

# PPT Writer Agent
AGENT_PPT_WRITER_PROVIDER=deepseek
AGENT_PPT_WRITER_MODEL=deepseek-chat
AGENT_PPT_WRITER_FALLBACK_MODEL=deepseek-chat
AGENT_PPT_WRITER_TEMPERATURE=0.5
AGENT_PPT_WRITER_MAX_TOKENS=4096
AGENT_PPT_WRITER_TIMEOUT=90
AGENT_PPT_WRITER_MAX_RETRIES=3

# PPT Checker Agent
AGENT_PPT_CHECKER_PROVIDER=deepseek
AGENT_PPT_CHECKER_MODEL=deepseek-chat
AGENT_PPT_CHECKER_TEMPERATURE=0.2
AGENT_PPT_CHECKER_MAX_TOKENS=2048
AGENT_PPT_CHECKER_TIMEOUT=60
AGENT_PPT_CHECKER_MAX_RETRIES=2
AGENT_PPT_CHECKER_ENABLE_FALLBACK=False  # 检查器不降级

# Outline Agent
AGENT_OUTLINE_PROVIDER=deepseek
AGENT_OUTLINE_MODEL=deepseek-chat
AGENT_OUTLINE_FALLBACK_MODEL=deepseek-chat
AGENT_OUTLINE_TEMPERATURE=0.7
AGENT_OUTLINE_MAX_TOKENS=8192
AGENT_OUTLINE_TIMEOUT=120
AGENT_OUTLINE_MAX_RETRIES=3
